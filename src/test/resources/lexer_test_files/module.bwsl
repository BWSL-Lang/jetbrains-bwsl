module Test1 {
    rotate :: (float2 pos, float2 center, float angle) -> float2 {
        float2 normalized = pos - center;
        float2 result = float2(
            normalized.x * cos(angle) + normalized.y * sin(angle),
            -normalized.x * sin(angle) + normalized.y * cos(angle)
        );
        return center + result;
    }

    rotate90DegreesAroundOrigo :: (float2 pos) -> float2 {
        if (pos == 0) {
            return pos;
        }
        return rotate(pos, float2(0), 3.14*0.5);
    }
}

module LengthMethodTest {
    test :: (float[5] values) -> float {
        float sum = 0.0;
        for (int i = 0; i < values.length(); i++) {
            values.cos();
            sum += values[i];
        }
        return sum + length(vec3(1, 2, 3));
    }
    struct testStruct {
        float m1;
        int m2;
        test :: () -> float {
            return m1 + float(m2);
        }
    }
}

module LengthTest2 {
    test2 :: () -> float {
        float[5] values;
        return LengthMethodTest::test(values);
    }
    test3 :: () -> void {
        LengthMethodTest::testStruct s;
        s.test();
    }
}